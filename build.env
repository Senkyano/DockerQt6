# ============================================================
# build.env — Configuration universelle Qt6 Builder
# Copiez ce fichier à la racine de CHAQUE projet Qt6
# et adaptez les valeurs ci-dessous.
# ============================================================
 
# ┌─────────────────────────────────────────────────────────┐
# │  PROJET À COMPILER                                      │
# │  Nom du dossier dans ./projects/                        │
# └─────────────────────────────────────────────────────────┘
 
PROJECT=Interface
 
# ┌─────────────────────────────────────────────────────────┐
# │  IDENTITÉ DU PROJET                                     │
# └─────────────────────────────────────────────────────────┘
 
# Nom de l'exécutable généré par CMake (= nom dans add_executable())
APP_NAME=DroneProto
 
# Dossier contenant vos fichiers .qml (relatif à la racine du projet)
# Exemples : ui  /  qml  /  src/ui  /  resources/qml
QML_DIR=ui
 
# Mettre à "false" si votre projet n'utilise pas QML/QtQuick
USE_QML=true
 
 
# ┌─────────────────────────────────────────────────────────┐
# │  MODULES Qt6 SUPPLÉMENTAIRES                            │
# │  (séparés par des espaces)                              │
# │  Ces modules s'ajoutent aux modules de base déjà        │
# │  installés : Core, Gui, Qml, Quick, Quick.Controls      │
# └─────────────────────────────────────────────────────────┘
 
# Décommentez les lignes dont vous avez besoin :
 
QT_EXTRA_MODULES=\
# qt6-multimedia-dev \        # QMediaPlayer, QCamera, QAudioOutput
# qt6-charts-dev \            # QtCharts (graphiques)
# qt6-serialport-dev \        # QSerialPort (UART, drone !)
# qt6-websockets-dev \        # QWebSocket
# qt6-3d-dev \                # Qt3D (scène 3D)
# libqt6svg6-dev \            # SVG rendering
# qt6-connectivity-dev \      # Bluetooth / NFC
# qt6-location-dev \          # GPS / cartes
# qt6-sensors-dev \           # Accéléromètre, gyroscope
# qt6-remoteobjects-dev \     # Qt Remote Objects
# qt6-serialbus-dev \         # CAN bus, Modbus
# qt6-networkauth-dev \       # OAuth2
# libqt6sql6 qt6-base-dev     # Base de données SQL
 
 
# ┌─────────────────────────────────────────────────────────┐
# │  CIBLES DE BUILD                                        │
# │  Mettez "true" pour activer, "false" pour désactiver    │
# └─────────────────────────────────────────────────────────┘
 
BUILD_LINUX_X86_64=true
BUILD_LINUX_ARM64=false
BUILD_WINDOWS=false
BUILD_ANDROID=false
 
 
# ┌─────────────────────────────────────────────────────────┐
# │  ANDROID (uniquement si BUILD_ANDROID=true)             │
# └─────────────────────────────────────────────────────────┘
 
# Identifiant unique de l'application Android (reverse domain)
ANDROID_PACKAGE=com.drone.proto
 
# SDK Android minimum (28 = Android 9 Pie)
ANDROID_MIN_SDK=28
 
# SDK Android cible (33 = Android 13)
ANDROID_TARGET_SDK=33
 
 
# ┌─────────────────────────────────────────────────────────┐
# │  OPTIONS AVANCÉES                                       │
# └─────────────────────────────────────────────────────────┘
 
# Type de build CMake : Release | Debug | RelWithDebInfo
CMAKE_BUILD_TYPE=Release
 
# Chemin vers une icône personnalisée (PNG 256x256)
# Laissez vide pour utiliser l'icône par défaut
# ICON_PATH=assets/icon.png
 